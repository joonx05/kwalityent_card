// Prisma schema (Prisma 6)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Card {
  id        String   @id @default(cuid())
  name      String
  profession String
  Company   String
  hobbie    String
  profile_image_url String
  cover_image_url String

  // Optional links (default null)
  personal_website_link String?
  instagram            String?
  whatsapp             String?
  twitter              String?
  mobile               String?
  telegram             String?
  linkedin             String?
  gmail                String?

  @@map("cards")
}
